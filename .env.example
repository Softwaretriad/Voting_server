PORT=5000
ENFORCE_HTTPS=false
TRUST_PROXY_HOPS=1
JSON_BODY_LIMIT=25mb
INPUT_DEFAULT_MAX_LENGTH=2000
INPUT_DEFAULT_MAX_ARRAY_ITEMS=1000
INPUT_MAX_DEPTH=10
INPUT_MAX_OBJECT_KEYS=200
MONGO_URI=mongodb://127.0.0.1:27017/myunivote
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=0
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_RETRY_WRITES=true

JWT_SECRET=replace-with-a-strong-secret
PIN_HASH_SECRET=replace-with-a-strong-pin-hash-secret
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d
JWT_EC_EXPIRATION=8h
JWT_EC_REFRESH_EXPIRATION=14d
JWT_SCHOOL_ADMIN_EXPIRATION=2h
JWT_SCHOOL_ADMIN_REFRESH_EXPIRATION=7d
SCHOOL_ADMIN_ACCESS_COOKIE_MAX_AGE_MS=7200000
SCHOOL_ADMIN_REFRESH_COOKIE_MAX_AGE_MS=604800000
SCHOOL_ADMIN_COOKIE_DOMAIN=
SCHOOL_ADMIN_BOOTSTRAP_KEY=replace-with-a-strong-school-admin-bootstrap-key

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_POOL=true
SMTP_MAX_CONNECTIONS=1
SMTP_MAX_MESSAGES=25
EMAIL_USER=your-email@example.com
EMAIL_PASS=replace-with-email-password
EMAIL_FROM=MyUniVote <no-reply@example.com>
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
SENDGRID_FROM=MyUniVote <no-reply@example.com>
SENDGRID_REPLY_TO=

SOCKET_DEBUG=false
OPS_METRICS_TOKEN=replace-with-a-strong-ops-token
SCHOOL_PROMOTION_BOOTSTRAP_KEY=replace-with-a-strong-bootstrap-key
# Leave blank for local memory fallback, set in production for shared rate limits/cache.
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_URL=redis://:replace-with-a-strong-redis-password@redis:6379
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
MONITOR_CACHE_TTL_SECONDS=3
STUDENT_ELECTION_LIST_CACHE_TTL_SECONDS=3
POST_VOTE_SIDE_EFFECTS_ENABLED=true
POST_VOTE_SIDE_EFFECT_MODE=queue
POST_VOTE_SIDE_EFFECT_CONCURRENCY=1
VOTE_SIDE_EFFECT_WORKER_INTERVAL_MS=1000
VOTE_SIDE_EFFECT_WORKER_BATCH_SIZE=25
VOTE_TARGET_CACHE_TTL_SECONDS=5
VOTE_ELIGIBILITY_CACHE_TTL_SECONDS=30
ELECTION_VOTER_SET_CACHE_TTL_SECONDS=30
ELIGIBILITY_SOURCE=voter_collection
VOTE_TIMING_DEBUG=false
# Keep false when running `npm run worker:elections`; use true only if the API process is the lifecycle runner.
ELECTION_LIFECYCLE_IN_API=false
ELECTION_LIFECYCLE_ENABLED=true
ELECTION_LIFECYCLE_INTERVAL_MS=15000
# Keep false when running the lifecycle worker; true only if reads must self-heal stale statuses.
ELECTION_LIFECYCLE_ON_READ=false
ANALYTICS_WORKER_INTERVAL_MS=5000
ANALYTICS_WORKER_BATCH_SIZE=100

# FCM remote push
# Option A: provide the full Firebase service account JSON as one escaped JSON string
FCM_SERVICE_ACCOUNT_JSON=

# Option B: provide the required values directly
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Firebase Cloud Storage uploads
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
IMAGE_UPLOAD_MAX_BYTES=5242880
IMAGE_UPLOAD_MAX_PIXELS=40000000
IMAGE_UPLOAD_MAX_DIMENSION=12000

# APNs remote push
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=

# Set to true for production APNs, false for sandbox/development
APNS_PRODUCTION=false
