            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "const adminToken = data.token || data.accessToken || '';",
                  "if (adminToken) pm.collectionVariables.set('adminToken', adminToken);",
                  "if (data.user && data.user.id) pm.collectionVariables.set('adminUserId', data.user.id);",
                  "if (data.user && data.user.schoolId) pm.collectionVariables.set('schoolId', data.user.schoolId);",
                  "pm.test('Response is admin login', function () {",
                  "  pm.expect(data.role).to.eql('admin');",
                  "});"
                ]
              }
            }
          ]
